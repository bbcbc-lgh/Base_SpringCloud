{
  "info": {
    "_postman_id": "6530b409-9ad8-45c6-ae3f-47401259fd25",
    "name": "SpringCloud Alibaba 接口测试集",
    "description": "覆盖注册、登录、查询用户、查询库存、创建订单、查询订单、查询消息记录，以及未携带 Token、库存不足等异常场景。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 注册用户",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\",\n  \"role\": \"USER\"\n}"
        },
        "url": "{{baseUrl}}/auth/register"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('注册接口返回成功结构', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 400]);",
              "});",
              "if (pm.response.code === 200) {",
              "  const json = pm.response.json();",
              "  if (json.data && json.data.token) pm.environment.set('token', json.data.token);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "02 登录获取 Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('登录成功并返回 Token', function () {",
              "  pm.response.to.have.status(200);",
              "  const json = pm.response.json();",
              "  pm.expect(json.code).to.eql(0);",
              "  pm.expect(json.data.token).to.be.a('string').and.not.empty;",
              "  pm.environment.set('token', json.data.token);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "03 查询登录用户",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/auth/me"
      }
    },
    {
      "name": "04 查询用户信息",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/users/me"
      }
    },
    {
      "name": "05 查询库存",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/stock/{{productCode}}"
      }
    },
    {
      "name": "06 创建订单并扣减库存",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productCode\": \"{{productCode}}\",\n  \"quantity\": {{quantity}},\n  \"amount\": {{amount}}\n}"
        },
        "url": "{{baseUrl}}/orders"
      }
    },
    {
      "name": "07 查询我的订单",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/orders/my"
      }
    },
    {
      "name": "08 查询消息记录",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/messages/events"
      }
    },
    {
      "name": "09 异常-未携带 Token 查询订单",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/orders/my"
      }
    },
    {
      "name": "10 异常-库存不足",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productCode\": \"{{productCode}}\",\n  \"quantity\": 99999,\n  \"amount\": 999.00\n}"
        },
        "url": "{{baseUrl}}/orders"
      }
    }
  ]
}
